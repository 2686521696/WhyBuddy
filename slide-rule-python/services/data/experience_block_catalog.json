{
  "$comment": "体验区块目录——页面区块合法域的唯一真相源。Python Gate/Repair/Prompt 与前端 Renderer Registry 共同消费；本版只建立目录和渲染边界，不改变旧页面效果。",
  "version": 1,
  "allowedSlots": ["summary", "primary", "secondary", "activity", "content"],
  "dataKinds": [
    "aggregate",
    "series",
    "rankedRows",
    "timelineRows",
    "entityRows"
  ],
  "eventTypes": [
    "metricSelect",
    "pointSelect",
    "itemSelect",
    "rowSelect",
    "createRequest",
    "editRequest",
    "actionTrigger",
    "filterChange"
  ],
  "blocks": [
    {
      "type": "MetricGrid",
      "description": "一组关键指标卡，用于页面摘要区域。",
      "rendererKey": "metric-grid",
      "propsSchema": {
        "type": "object",
        "additionalProperties": false,
        "properties": {
          "title": { "type": "string" }
        }
      },
      "dataKinds": ["aggregate"],
      "allowedSlots": ["summary", "primary"],
      "events": ["metricSelect"],
      "bindingHints": "entityRef必填，aggregate支持 count/sum:<fieldId>/avg:<fieldId>，可选filter"
    },
    {
      "type": "TrendChart",
      "description": "按时间或有序维度展示变化趋势。",
      "rendererKey": "trend-chart",
      "propsSchema": {
        "type": "object",
        "additionalProperties": false,
        "properties": {
          "title": { "type": "string" }
        }
      },
      "dataKinds": ["series"],
      "allowedSlots": ["primary", "secondary"],
      "events": ["pointSelect"],
      "bindingHints": "entityRef+timeDimensionRef必填，timeGrain=day/week/month，可选seriesBy分多系列"
    },
    {
      "type": "RankedList",
      "description": "按数值排序的业务排行。",
      "rendererKey": "ranked-list",
      "propsSchema": {
        "type": "object",
        "additionalProperties": false,
        "properties": {
          "title": { "type": "string" }
        }
      },
      "dataKinds": ["rankedRows"],
      "allowedSlots": ["primary", "secondary"],
      "events": ["itemSelect"],
      "bindingHints": "entityRef+sortByRef必填（number字段），limit 3-20，sortOrder=desc/asc"
    },
    {
      "type": "ActivityFeed",
      "description": "按时间倒序展示动态、提醒或风险事件。",
      "rendererKey": "activity-feed",
      "propsSchema": {
        "type": "object",
        "additionalProperties": false,
        "properties": {
          "title": { "type": "string" }
        }
      },
      "dataKinds": ["timelineRows"],
      "allowedSlots": ["activity", "secondary"],
      "events": ["itemSelect"],
      "bindingHints": "entityRef+timeFieldRef必填（date字段），可选levelFieldRef（enum字段）"
    },
    {
      "type": "DataTable",
      "description": "展示实体记录并承接行级业务操作。",
      "rendererKey": "data-table",
      "propsSchema": {
        "type": "object",
        "additionalProperties": false,
        "properties": {
          "title": { "type": "string" }
        }
      },
      "dataKinds": ["entityRows"],
      "allowedSlots": ["primary", "content"],
      "events": ["rowSelect", "createRequest", "editRequest"],
      "bindingHints": "entityRef必填，其余字段由页面columns派生，binding可省略"
    },
    {
      "type": "QuickActionPanel",
      "description": "CRM/任务工作台的快捷业务操作按钮组，适合工作台首页的常用动作入口。",
      "rendererKey": "quick-action-panel",
      "propsSchema": {
        "type": "object",
        "additionalProperties": false,
        "properties": {
          "title": { "type": "string" },
          "columns": { "type": "number", "minimum": 1, "maximum": 4 }
        }
      },
      "bindingHints": "无需 entityRef。actions 数组里的 createRecord/navigate 类型动作作为入口按钮。",
      "dataKinds": [],
      "allowedSlots": ["summary", "primary"],
      "events": ["actionTrigger"]
    },
    {
      "type": "FilterBar",
      "description": "时间范围和枚举条件筛选栏，适合经营大盘、舆情监控等需要全局筛选的页面顶部。",
      "rendererKey": "filter-bar",
      "propsSchema": {
        "type": "object",
        "additionalProperties": false,
        "properties": {
          "title": { "type": "string" },
          "showDateRange": { "type": "boolean" }
        }
      },
      "bindingHints": "entityRef 可选。filterFields 列出可筛选的枚举字段 id。触发 changeFilter 动作刷新同页面其他区块。",
      "dataKinds": ["aggregate"],
      "allowedSlots": ["summary"],
      "events": ["filterChange"]
    }
  ]
}
