{
  "$comment": "体验区块目录——页面区块合法域的唯一真相源。Python Gate/Repair/Prompt 与前端 Renderer Registry 共同消费；本版只建立目录和渲染边界，不改变旧页面效果。bindingSchema 是 binding 字段的唯一结构化定义：Prompt 文案和 Gate 校验都从这里派生，不再各写一份。",
  "version": 2,
  "allowedSlots": ["summary", "primary", "secondary", "activity", "content"],
  "dataKinds": [
    "aggregate",
    "series",
    "rankedRows",
    "timelineRows",
    "entityRows"
  ],
  "eventTypes": [
    "metricSelect",
    "pointSelect",
    "itemSelect",
    "rowSelect",
    "createRequest",
    "editRequest",
    "actionTrigger",
    "filterChange"
  ],
  "blocks": [
    {
      "type": "MetricGrid",
      "description": "一组关键指标卡，用于页面摘要区域。",
      "rendererKey": "metric-grid",
      "propsSchema": {
        "type": "object",
        "additionalProperties": false,
        "properties": {
          "title": { "type": "string" }
        }
      },
      "dataKinds": ["aggregate"],
      "allowedSlots": ["summary", "primary"],
      "events": ["metricSelect"],
      "bindingSchema": {
        "required": ["entityRef"],
        "optional": ["aggregate", "filter"],
        "aggregateFields": ["aggregate"]
      }
    },
    {
      "type": "TrendChart",
      "description": "按时间或有序维度展示变化趋势。",
      "rendererKey": "trend-chart",
      "propsSchema": {
        "type": "object",
        "additionalProperties": false,
        "properties": {
          "title": { "type": "string" }
        }
      },
      "dataKinds": ["series"],
      "allowedSlots": ["primary", "secondary"],
      "events": ["pointSelect"],
      "bindingSchema": {
        "required": ["entityRef", "timeDimensionRef"],
        "optional": ["timeGrain", "seriesBy"],
        "enums": { "timeGrain": ["day", "week", "month"] },
        "entityFieldRefs": { "timeDimensionRef": "date", "seriesBy": "enum" }
      }
    },
    {
      "type": "RankedList",
      "description": "按数值排序的业务排行。",
      "rendererKey": "ranked-list",
      "propsSchema": {
        "type": "object",
        "additionalProperties": false,
        "properties": {
          "title": { "type": "string" }
        }
      },
      "dataKinds": ["rankedRows"],
      "allowedSlots": ["primary", "secondary"],
      "events": ["itemSelect"],
      "bindingSchema": {
        "required": ["entityRef", "sortByRef"],
        "optional": ["sortOrder", "limit"],
        "enums": { "sortOrder": ["asc", "desc"] },
        "entityFieldRefs": { "sortByRef": "number" },
        "ranges": { "limit": [3, 20] }
      }
    },
    {
      "type": "ActivityFeed",
      "description": "按时间倒序展示动态、提醒或风险事件。",
      "rendererKey": "activity-feed",
      "propsSchema": {
        "type": "object",
        "additionalProperties": false,
        "properties": {
          "title": { "type": "string" }
        }
      },
      "dataKinds": ["timelineRows"],
      "allowedSlots": ["activity", "secondary"],
      "events": ["itemSelect"],
      "bindingSchema": {
        "required": ["entityRef", "timeFieldRef"],
        "optional": ["levelFieldRef"],
        "entityFieldRefs": { "timeFieldRef": "date", "levelFieldRef": "enum" }
      }
    },
    {
      "type": "DataTable",
      "description": "展示实体记录并承接行级业务操作。",
      "rendererKey": "data-table",
      "propsSchema": {
        "type": "object",
        "additionalProperties": false,
        "properties": {
          "title": { "type": "string" }
        }
      },
      "dataKinds": ["entityRows"],
      "allowedSlots": ["primary", "content"],
      "events": ["rowSelect", "createRequest", "editRequest"],
      "bindingSchema": {
        "required": ["entityRef"],
        "optional": [],
        "note": "其余列由页面 columns 派生；binding 对象整体可省略，省略时不受 required 约束。"
      }
    },
    {
      "type": "QuickActionPanel",
      "description": "CRM/任务工作台的快捷业务操作按钮组，适合工作台首页的常用动作入口。",
      "rendererKey": "quick-action-panel",
      "propsSchema": {
        "type": "object",
        "additionalProperties": false,
        "properties": {
          "title": { "type": "string" },
          "columns": { "type": "number", "minimum": 1, "maximum": 4 }
        }
      },
      "dataKinds": [],
      "allowedSlots": ["summary", "primary"],
      "events": ["actionTrigger"],
      "bindingSchema": {
        "required": [],
        "optional": [],
        "note": "不使用 binding；入口按钮由 actions[] 里的 createRecord/navigate 类型动作声明。"
      }
    },
    {
      "type": "FilterBar",
      "description": "时间范围和枚举条件筛选栏，适合经营大盘、舆情监控等需要全局筛选的页面顶部。",
      "rendererKey": "filter-bar",
      "propsSchema": {
        "type": "object",
        "additionalProperties": false,
        "properties": {
          "title": { "type": "string" },
          "showDateRange": { "type": "boolean" }
        }
      },
      "dataKinds": ["aggregate"],
      "allowedSlots": ["summary"],
      "events": ["filterChange"],
      "bindingSchema": {
        "required": [],
        "optional": ["entityRef"],
        "note": "可筛选字段在 props.filterFields 里声明（不是 binding）；entityRef 仅在需要按实体过滤时填写。触发 changeFilter 动作刷新同页面其他区块。"
      }
    }
  ]
}
