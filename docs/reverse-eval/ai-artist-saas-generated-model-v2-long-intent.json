  "workflow": {
    "id": "creative_job_lifecycle",
    "name": "AI创作任务生命周期",
    "nodes": [
      {
        "id": "cj_draft",
        "name": "创建画布与提交提示词",
        "assigneeRole": "end_user",
        "phase": "申请"
      },
      {
        "id": "cj_quota_check",
        "name": "校验套餐点数与能力权限",
        "assigneeRole": "tenant_operator",
        "phase": "申请"
      },
      {
        "id": "cj_dispatch",
        "name": "选择AI接口并冻结点数",
        "assigneeRole": "tenant_operator",
        "phase": "生成"
      },
      {
        "id": "cj_generate",
        "name": "调用AI生成图片视频语音素材",
        "assigneeRole": "tenant_operator",
        "phase": "生成"
      },
      {
        "id": "cj_quality_check",
        "name": "内容安全与质量验收",
        "assigneeRole": "content_moderator",
        "phase": "验收"
      },
      {
        "id": "cj_rejected",
        "name": "退回修改或取消任务",
        "assigneeRole": "end_user",
        "phase": "验收"
      },
      {
        "id": "cj_deliver",
        "name": "入库自有存储并交付素材",
        "assigneeRole": "tenant_operator",
        "phase": "交付"
      },
      {
        "id": "cj_archive",
        "name": "扣减点数并归档项目",
        "assigneeRole": "tenant_operator",
        "phase": "交付"
      }
    ],
    "transitions": [
      {
        "from": "cj_draft",
        "to": "cj_quota_check",
        "condition": "用户提交任务"
      },
      {
        "from": "cj_quota_check",
        "to": "cj_dispatch",
        "condition": "点数充足且能力已开通"
      },
      {
        "from": "cj_quota_check",
        "to": "cj_rejected",
        "condition": "点数不足或能力未开通"
      },
      {
        "from": "cj_dispatch",
        "to": "cj_generate",
        "condition": "AI接口可用"
      },
      {
        "from": "cj_dispatch",
        "to": "cj_draft",
        "condition": "接口配置缺失，退回修改需求"
      },
      {
        "from": "cj_generate",
        "to": "cj_quality_check",
        "condition": "生成成功"
      },
      {
        "from": "cj_generate",
        "to": "cj_dispatch",
        "condition": "供应商限流，切换接口重试"
      },
      {
        "from": "cj_quality_check",
        "to": "cj_deliver",
        "condition": "审核通过"
      },
      {
        "from": "cj_quality_check",
        "to": "cj_draft",
        "condition": "审核不通过，退回用户调整提示词"
      },
      {
        "from": "cj_quality_check",
        "to": "cj_rejected",
        "condition": "违规内容终止"
      },
      {
        "from": "cj_deliver",
        "to": "cj_archive",
        "condition": "素材已重托管到自有存储"
      }
    ],
    "chains": [
      {
        "id": "tenant_recharge_money_chain",
        "name": "租户套餐充值与点数入账",
        "kind": "money",
        "nodes": [
          {
            "id": "mp_create_order",
            "name": "选择套餐并创建支付订单",
            "assigneeRole": "tenant_admin",
            "phase": "下单"
          },
          {
            "id": "mp_gateway_pay",
            "name": "跳转支付网关付款",
            "assigneeRole": "tenant_admin",
            "phase": "支付"
          },
          {
            "id": "mp_server_confirm",
            "name": "服务端验签确认支付回调",
            "assigneeRole": "finance_admin",
            "phase": "支付"
          },
          {
            "id": "mp_credit_wallet",
            "name": "点数入账并生成流水",
            "assigneeRole": "finance_admin",
            "phase": "入账"
          },
          {
            "id": "mp_reconcile",
            "name": "支付订单与点数流水对账",
            "assigneeRole": "finance_admin",
            "phase": "对账"
          },
          {
            "id": "mp_payment_failed",
            "name": "支付失败关闭订单",
            "assigneeRole": "finance_admin",
            "phase": "对账"
          }
        ],
        "transitions": [
          {
            "from": "mp_create_order",
            "to": "mp_gateway_pay",
            "condition": "订单金额与套餐有效"
          },
          {
            "from": "mp_gateway_pay",
            "to": "mp_server_confirm",
            "condition": "网关返回待确认"
          },
          {
            "from": "mp_gateway_pay",
            "to": "mp_create_order",
            "condition": "用户取消或支付超时重新下单"
          },
          {
            "from": "mp_server_confirm",
            "to": "mp_credit_wallet",
            "condition": "验签成功且金额一致"
          },
          {
            "from": "mp_server_confirm",
            "to": "mp_payment_failed",
            "condition": "验签失败或金额不一致"
          },
          {
            "from": "mp_credit_wallet",
            "to": "mp_reconcile",
            "condition": "钱包余额更新完成"
          },
          {
            "from": "mp_reconcile",
            "to": "mp_credit_wallet",
            "condition": "对账发现入账缺失，补记流水"
          },
          {
            "from": "mp_reconcile",
            "to": "mp_payment_failed",
            "condition": "对账确认异常不可补偿"
          }
        ]
      },
      {
        "id": "platform_config_governance_chain",
        "name": "平台插件与AI接口配置治理",
        "kind": "governance",
        "nodes": [
          {
            "id": "gv_submit_config",
            "name": "提交插件或AI接口配置变更",
            "assigneeRole": "tenant_admin",
            "phase": "提交"
          },
          {
            "id": "gv_security_review",
            "name": "安全与合规审查",
            "assigneeRole": "platform_admin",
            "phase": "审核"
          },
          {
            "id": "gv_business_review",
            "name": "能力定价与套餐适配审核",
            "assigneeRole": "finance_admin",
            "phase": "审核"
          },
          {
            "id": "gv_publish_config",
            "name": "发布配置到租户工作台",
            "assigneeRole": "platform_admin",
            "phase": "发布"
          },
          {
            "id": "gv_return_config",
            "name": "退回配置修改",
            "assigneeRole": "tenant_admin",
            "phase": "发布"
          }
        ],
        "transitions": [
          {
            "from": "gv_submit_config",
            "to": "gv_security_review",
            "condition": "提交完整配置"
          },
          {
            "from": "gv_security_review",
            "to": "gv_business_review",
            "condition": "密钥、域名与权限校验通过"
          },
          {
            "from": "gv_security_review",
            "to": "gv_return_config",
            "condition": "发现不安全回调或越权范围"
          },
          {
            "from": "gv_business_review",
            "to": "gv_publish_config",
            "condition": "定价与套餐规则通过"
          },
          {
            "from": "gv_business_review",
            "to": "gv_return_config",
            "condition": "计费规则缺失或冲突"
          },
          {
            "from": "gv_return_config",
            "to": "gv_submit_config",
            "condition": "租户修正后重新提交"
          }
        ]
      },
      {
        "id": "generation_recovery_chain",
        "name": "异步生成失败补偿与清理",
        "kind": "recovery",
        "nodes": [
          {
            "id": "rc_detect_failure",
            "name": "发现生成超时或供应商失败",
            "assigneeRole": "tenant_operator",
            "phase": "发现"
          },
          {
            "id": "rc_retry_provider",
            "name": "重试原供应商或切换备用接口",
            "assigneeRole": "tenant_operator",
            "phase": "补偿"
          },
          {
            "id": "rc_refund_credit",
            "name": "解冻或退回点数",
            "assigneeRole": "finance_admin",
            "phase": "补偿"
          },
          {
            "id": "rc_cleanup_temp",
            "name": "清理临时文件与半成品素材",
            "assigneeRole": "tenant_operator",
            "phase": "补偿"
          },
          {
            "id": "rc_close_case",
            "name": "关闭补偿工单并记录审计",
            "assigneeRole": "tenant_operator",
            "phase": "关闭"
          },
          {
            "id": "rc_escalate_manual",
            "name": "升级人工处理",
            "assigneeRole": "platform_admin",
            "phase": "关闭"
          }
        ],
        "transitions": [
          {
            "from": "rc_detect_failure",
            "to": "rc_retry_provider",
            "condition": "失败次数未超过阈值"
          },
          {
            "from": "rc_detect_failure",
            "to": "rc_refund_credit",
            "condition": "不可重试或用户取消"
          },
          {
            "from": "rc_retry_provider",
            "to": "rc_close_case",
            "condition": "重试成功并交付素材"
          },
          {
            "from": "rc_retry_provider",
            "to": "rc_refund_credit",
            "condition": "重试失败达到阈值"
          },
          {
            "from": "rc_retry_provider",
            "to": "rc_detect_failure",
            "condition": "异步状态未知，继续观察"
          },
          {
            "from": "rc_refund_credit",
            "to": "rc_cleanup_temp",
            "condition": "点数已退回或解冻"
          },
          {
            "from": "rc_cleanup_temp",
            "to": "rc_close_case",
            "condition": "临时资源清理成功"
          },
          {
            "from": "rc_cleanup_temp",
            "to": "rc_escalate_manual",
            "condition": "存储清理失败需要人工介入"
          }
        ]
      }
    ]
  },
