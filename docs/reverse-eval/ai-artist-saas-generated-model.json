  "workflow": {
    "id": "tenant_configuration_publish_workflow",
    "nodes": [
      {
        "id": "submit_configuration",
        "name": "提交租户配置变更",
        "assigneeRole": "tenant_admin",
        "phase": "配置"
      },
      {
        "id": "review_ai_interface",
        "name": "审核AI接口与模型",
        "assigneeRole": "platform_admin",
        "phase": "审核"
      },
      {
        "id": "review_recharge_plan",
        "name": "审核套餐充值规则",
        "assigneeRole": "finance_operator",
        "phase": "审核"
      },
      {
        "id": "review_page_theme",
        "name": "审核页面装修合规",
        "assigneeRole": "platform_admin",
        "phase": "审核"
      },
      {
        "id": "activate_configuration",
        "name": "发布并启用配置",
        "assigneeRole": "tenant_admin",
        "phase": "发布"
      }
    ],
    "transitions": [
      {
        "from": "submit_configuration",
        "to": "review_ai_interface",
        "condition": "包含AI接口、模型或插件变更"
      },
      {
        "from": "submit_configuration",
        "to": "review_recharge_plan",
        "condition": "仅包含套餐充值或计费规则变更"
      },
      {
        "from": "review_ai_interface",
        "to": "review_page_theme",
        "condition": "AI接口审核通过"
      },
      {
        "from": "review_ai_interface",
        "to": "submit_configuration",
        "condition": "AI接口审核驳回，退回修改"
      },
      {
        "from": "review_recharge_plan",
        "to": "review_page_theme",
        "condition": "套餐计费审核通过"
      },
      {
        "from": "review_recharge_plan",
        "to": "submit_configuration",
        "condition": "套餐计费审核驳回，退回修改"
      },
      {
        "from": "review_page_theme",
        "to": "activate_configuration",
        "condition": "页面装修审核通过"
      },
      {
        "from": "review_page_theme",
        "to": "submit_configuration",
        "condition": "页面装修审核驳回，退回修改"
      }
    ]
  },
