  "workflow": {
    "id": "creative_request_lifecycle",
    "name": "AI创作请求生命周期",
    "nodes": [
      {
        "id": "cr_draft",
        "name": "填写创作需求",
        "assigneeRole": "tenant_user",
        "phase": "申请"
      },
      {
        "id": "cr_policy_check",
        "name": "提示词与租户策略校验",
        "assigneeRole": "tenant_admin",
        "phase": "校验"
      },
      {
        "id": "cr_quota_check",
        "name": "点数余额校验",
        "assigneeRole": "finance_admin",
        "phase": "校验"
      },
      {
        "id": "cr_wait_recharge",
        "name": "等待充值补足点数",
        "assigneeRole": "tenant_user",
        "phase": "校验"
      },
      {
        "id": "cr_rejected",
        "name": "请求驳回",
        "assigneeRole": "tenant_admin",
        "phase": "校验"
      },
      {
        "id": "cr_dispatch_generation",
        "name": "调用AI接口生成",
        "assigneeRole": "ops_engineer",
        "phase": "生成"
      },
      {
        "id": "cr_content_review",
        "name": "作品内容审核",
        "assigneeRole": "content_reviewer",
        "phase": "生成"
      },
      {
        "id": "cr_deliver_asset",
        "name": "交付作品到用户工作台",
        "assigneeRole": "tenant_user",
        "phase": "交付"
      },
      {
        "id": "cr_archive",
        "name": "归档创作记录",
        "assigneeRole": "tenant_admin",
        "phase": "交付"
      }
    ],
    "transitions": [
      {
        "from": "cr_draft",
        "to": "cr_policy_check",
        "condition": "用户提交创作请求"
      },
      {
        "from": "cr_policy_check",
        "to": "cr_quota_check",
        "condition": "提示词与租户策略通过"
      },
      {
        "from": "cr_policy_check",
        "to": "cr_draft",
        "condition": "提示词需用户修改"
      },
      {
        "from": "cr_policy_check",
        "to": "cr_rejected",
        "condition": "命中禁止内容"
      },
      {
        "from": "cr_quota_check",
        "to": "cr_dispatch_generation",
        "condition": "点数充足并冻结成功"
      },
      {
        "from": "cr_quota_check",
        "to": "cr_wait_recharge",
        "condition": "点数不足"
      },
      {
        "from": "cr_wait_recharge",
        "to": "cr_quota_check",
        "condition": "充值完成后重新校验"
      },
      {
        "from": "cr_dispatch_generation",
        "to": "cr_content_review",
        "condition": "AI生成任务成功返回"
      },
      {
        "from": "cr_content_review",
        "to": "cr_deliver_asset",
        "condition": "内容审核通过"
      },
      {
        "from": "cr_content_review",
        "to": "cr_draft",
        "condition": "内容审核退回重新创作"
      },
      {
        "from": "cr_deliver_asset",
        "to": "cr_archive",
        "condition": "用户可访问自有存储作品"
      }
    ],
    "chains": [
      {
        "id": "recharge_money_chain",
        "name": "套餐充值与点数入账链",
        "kind": "money",
        "nodes": [
          {
            "id": "pay_select_plan",
            "name": "选择充值套餐",
            "assigneeRole": "tenant_user",
            "phase": "下单"
          },
          {
            "id": "pay_create_order",
            "name": "创建支付单",
            "assigneeRole": "tenant_admin",
            "phase": "下单"
          },
          {
            "id": "pay_user_submit",
            "name": "跳转支付并提交付款",
            "assigneeRole": "tenant_user",
            "phase": "支付"
          },
          {
            "id": "pay_gateway_callback",
            "name": "接收支付网关回调",
            "assigneeRole": "finance_admin",
            "phase": "支付"
          },
          {
            "id": "pay_verify_callback",
            "name": "服务端验签与金额校验",
            "assigneeRole": "finance_admin",
            "phase": "支付"
          },
          {
            "id": "pay_rejected",
            "name": "支付单关闭",
            "assigneeRole": "finance_admin",
            "phase": "支付"
          },
          {
            "id": "pay_wallet_credit",
            "name": "充值点数入钱包",
            "assigneeRole": "finance_admin",
            "phase": "入账"
          },
          {
            "id": "pay_ledger_record",
            "name": "写入点数流水",
            "assigneeRole": "finance_admin",
            "phase": "入账"
          },
          {
            "id": "pay_finance_audit",
            "name": "财务对账归档",
            "assigneeRole": "finance_admin",
            "phase": "审计"
          }
        ],
        "transitions": [
          {
            "from": "pay_select_plan",
            "to": "pay_create_order",
            "condition": "租户确认套餐"
          },
          {
            "from": "pay_create_order",
            "to": "pay_user_submit",
            "condition": "支付单创建成功"
          },
          {
            "from": "pay_user_submit",
            "to": "pay_gateway_callback",
            "condition": "网关返回异步通知"
          },
          {
            "from": "pay_gateway_callback",
            "to": "pay_verify_callback",
            "condition": "收到带签名回调"
          },
          {
            "from": "pay_verify_callback",
            "to": "pay_wallet_credit",
            "condition": "验签成功且金额一致"
          },
          {
            "from": "pay_verify_callback",
            "to": "pay_user_submit",
            "condition": "回调缺失或状态待定，等待用户重试"
          },
          {
            "from": "pay_verify_callback",
            "to": "pay_rejected",
            "condition": "验签失败或金额不一致"
          },
          {
            "from": "pay_wallet_credit",
            "to": "pay_ledger_record",
            "condition": "钱包余额更新成功"
          },
          {
            "from": "pay_ledger_record",
            "to": "pay_finance_audit",
            "condition": "流水与支付单已关联"
          }
        ]
      },
      {
        "id": "tenant_configuration_governance",
        "name": "租户AI接口与插件配置治理链",
        "kind": "governance",
        "nodes": [
          {
            "id": "cfg_submit",
            "name": "提交接口或插件配置",
            "assigneeRole": "tenant_admin",
            "phase": "提交"
          },
          {
            "id": "cfg_security_review",
            "name": "平台安全审查",
            "assigneeRole": "platform_admin",
            "phase": "审核"
          },
          {
            "id": "cfg_business_review",
            "name": "业务可用性审查",
            "assigneeRole": "ops_engineer",
            "phase": "审核"
          },
          {
            "id": "cfg_return_modify",
            "name": "退回修改配置",
            "assigneeRole": "tenant_admin",
            "phase": "审核"
          },
          {
            "id": "cfg_rejected",
            "name": "配置驳回",
            "assigneeRole": "platform_admin",
            "phase": "审核"
          },
          {
            "id": "cfg_publish",
            "name": "发布配置到租户",
            "assigneeRole": "platform_admin",
            "phase": "发布"
          },
          {
            "id": "cfg_audit_log",
            "name": "记录配置审计日志",
            "assigneeRole": "platform_admin",
            "phase": "发布"
          }
        ],
        "transitions": [
          {
            "from": "cfg_submit",
            "to": "cfg_security_review",
            "condition": "租户管理员提交"
          },
          {
            "from": "cfg_security_review",
            "to": "cfg_business_review",
            "condition": "密钥、域名与权限检查通过"
          },
          {
            "from": "cfg_security_review",
            "to": "cfg_return_modify",
            "condition": "存在可修复安全问题"
          },
          {
            "from": "cfg_security_review",
            "to": "cfg_rejected",
            "condition": "存在高危配置"
          },
          {
            "from": "cfg_return_modify",
            "to": "cfg_submit",
            "condition": "租户完成修改后重新提交"
          },
          {
            "from": "cfg_business_review",
            "to": "cfg_publish",
            "condition": "连通性和额度策略验证通过"
          },
          {
            "from": "cfg_business_review",
            "to": "cfg_return_modify",
            "condition": "接口连通性失败需修改"
          },
          {
            "from": "cfg_publish",
            "to": "cfg_audit_log",
            "condition": "配置生效"
          }
        ]
      },
      {
        "id": "async_generation_recovery",
        "name": "异步生成失败恢复链",
        "kind": "recovery",
        "nodes": [
          {
            "id": "rec_detect_failure",
            "name": "发现生成任务失败",
            "assigneeRole": "ops_engineer",
            "phase": "发现"
          },
          {
            "id": "rec_classify_error",
            "name": "判定失败类型",
            "assigneeRole": "ops_engineer",
            "phase": "发现"
          },
          {
            "id": "rec_retry_provider",
            "name": "切换或重试AI接口",
            "assigneeRole": "ops_engineer",
            "phase": "重试"
          },
          {
            "id": "rec_verify_result",
            "name": "校验重试结果",
            "assigneeRole": "content_reviewer",
            "phase": "重试"
          },
          {
            "id": "rec_compensate_credit",
            "name": "补偿退还冻结点数",
            "assigneeRole": "finance_admin",
            "phase": "补偿"
          },
          {
            "id": "rec_notify_tenant",
            "name": "通知租户与用户",
            "assigneeRole": "tenant_admin",
            "phase": "补偿"
          },
          {
            "id": "rec_close_incident",
            "name": "关闭恢复事件",
            "assigneeRole": "ops_engineer",
            "phase": "关闭"
          }
        ],
        "transitions": [
          {
            "from": "rec_detect_failure",
