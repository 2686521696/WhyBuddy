# ============================================================
# SlideRule — 环境配置
#   cp .env.example .env   然后填值（.env 已被 .gitignore 排除，永不提交）
#
# 只列一键部署与推演主线真正用到的配置；其余高级开关都有安全默认值，
# 需要时查 docs/ 与代码内注释（历史完整清单见 git 历史中的本文件旧版）。
# 任何真实 key 都不要写进本文件——它是要提交进仓库的模板。
# ============================================================

# ── LLM（核心配置）──────────────────────────────────────────
# 任意 OpenAI 兼容供应商（OpenAI / Azure / DashScope / OpenRouter /
# SiliconFlow / Moonshot / 智谱 …）。不填也能启动，但推演走确定性
# 模板回退，看不到真实 LLM 推演。
LLM_API_KEY=your_api_key_here
LLM_BASE_URL=https://api.openai.com/v1
LLM_MODEL=gpt-5.5

# 线控与手感（下面是长期实跑验证过的一组；按你的网关实测调整）
LLM_WIRE_API=chat_completions
LLM_STREAM=false
LLM_REASONING_EFFORT=medium
LLM_TIMEOUT_MS=600000
LLM_ROUTER_TIMEOUT_MS=600000
# 免输出截断保护的模型白名单（逗号分隔）
LLM_UNLIMITED_MODELS=gpt-5.5

# 你的路由没有 /embeddings 端点时保持 false（避免无谓的 404 请求）；
# 有 embedding 模型可改 true 启用语义向量检索
RAG_VECTOR_ENABLED=false

# 新颖意图由 LLM 生成五系统元模型（经结构门校验，fail-closed）
SLIDERULE_LLM_GENERATE_ENABLED=1

# ── 会话签名 ────────────────────────────────────────────────
# 生产环境换成 64 位随机 hex；本地开发任意非空值即可
SESSION_SECRET=replace_with_a_64_char_random_hex_secret

# ── 可选：evidence.search 全网检索 ──────────────────────────
# SerpAPI 兼容端点的 key；不填走 DuckDuckGo 回退，再不行如实降级
# WEB_SEARCH_API_KEY=
# WEB_SEARCH_API_URL=https://serpapi.com/search.json

# ── 可选：E2B 沙盒（code.run 执行工具）──────────────────────
# 填了 key 工具即可用；不填 fail-closed（工具自动不可用，不假装）。
# key 从 https://e2b.dev → Dashboard → API Keys 获取。
# E2B_API_KEY=

# ── 可选：账号功能（登录/邮箱验证码/projects）────────────────
# 推演主线不需要数据库。需要账号功能时：
#   docker compose --profile accounts up -d
# 本地非 Docker 环境自行准备 MySQL 并解开下面注释。
# DB_HOST=localhost
# DB_PORT=3306
# DB_NAME=sliderule
# DB_USER=root
# DB_PASSWORD=change_me
